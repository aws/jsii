  # @param optional [String, nil] You don't have to pass this.
  def initialize(required:, second_level:, optional: nil)
    @required = required
    @second_level = second_level.is_a?(Hash) ? ::JsiiCalc::SecondLevelStruct.new(**second_level.transform_keys(&:to_sym)) : second_level
    @optional = optional
  end

  # This is a required field.
  #
  # @return [String]
