        :second_level => "secondLevel",
        :optional => "optional",
      }
    end

    def to_jsii
      result = {}
      result.merge!({
        "required" => @required,
        "secondLevel" => @second_level,
        "optional" => @optional,
      })
      result.compact
    end
  end

