exports[`Generated code for "jsii-calc": <outDir>/ruby/jsii-calc.gemspec 1`] = `
Gem::Specification.new do |s|
  s.name        = 'jsii-calc'
  s.version     = '3.20.120'
  s.summary     = 'Ruby bindings for jsii-calc'
  s.description = 'A simple calcuator built on JSII.'
  s.authors     = ['Amazon Web Services']
  s.license     = 'Apache-2.0'
  s.homepage    = 'https://github.com/aws/jsii'
  s.files       = Dir["lib/**/*"] + Dir["sig/**/*"]
  s.required_ruby_version = '>= 3.3.0'
  s.add_dependency 'jsii-ruby-runtime', '< 0.0.1'
  s.add_dependency 'base64', '~> 0.2'
  s.add_dependency 'scope-jsii-calc-base', '< 0.0.1'
  s.add_dependency 'scope-jsii-calc-lib', '< 0.0.1'
end

`;

