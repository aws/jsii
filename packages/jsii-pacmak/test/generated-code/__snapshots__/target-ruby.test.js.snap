    {
      :abstract_property => { kind: :property, name: "abstractProperty", is_optional: false },
      :prop_from_interface => { kind: :property, name: "propFromInterface", is_optional: false },
      :abstract_method => { kind: :method, name: "abstractMethod", is_optional: false },
      :non_abstract_method => { kind: :method, name: "nonAbstractMethod", is_optional: false },
    }
  end

  # @return [String]
