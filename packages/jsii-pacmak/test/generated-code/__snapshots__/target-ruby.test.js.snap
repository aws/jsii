exports[`Generated code for "jsii-calc": <outDir>/ruby/lib/jsii-calc/_readme.rb 1`] = `
# # jsii Calculator
#
# This library is used to demonstrate and test the features of JSII
#
# ## How to use running sum API:
#
# First, create a calculator:
#
# \`\`\`ruby
# const calculator = new calc.Calculator();
# \`\`\`
#
# Then call some operations:
#
# \`\`\`ruby
# calculator.add(10);
# \`\`\`
#
# ## Code Samples
#
# \`\`\`ruby
# /* This is totes a magic comment in here, just you wait! */
# const foo = 'bar';
# \`\`\`
module JsiiCalc; end

`;

