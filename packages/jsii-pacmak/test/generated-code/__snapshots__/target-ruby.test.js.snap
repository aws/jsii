class JsiiCalc::AbstractClass < ::JsiiCalc::AbstractClassBase
  include ::JsiiCalc::IInterfaceImplementedByAbstractClass
  self.jsii_fqn = "jsii-calc.AbstractClass"
  Jsii::Object.register_jsii_fqn("jsii-calc.AbstractClass", self)

  def initialize
