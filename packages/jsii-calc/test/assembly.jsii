    "jsii-calc.CallbackStackTraceTest": {
      "abstract": true,
      "assembly": "jsii-calc",
      "docs": {
        "remarks": "The test pattern is:\n1. Host overrides `callbackProvider()` to call `HostStackTraceReader.capturedTrace()`\n   and return the result.\n2. Host calls `invokeCallback()`, which calls back into the host.\n3. The host's override makes a new request to the kernel to read the trace.\n4. The trace captured during that nested request should reflect the host's\n   callback call site, not the original `invokeCallback()` call site.",
        "stability": "stable",
        "summary": "Abstract class that exercises the callback flow for stack trace propagation."
      },
      "fqn": "jsii-calc.CallbackStackTraceTest",
